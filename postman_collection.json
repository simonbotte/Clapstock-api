    },
    {
      "name": "Catalog",
      "item": [
        {
          "name": "Generate catalog PDF",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/projects/{{projectCode}}/catalog.pdf",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "projects",
                "{{projectCode}}",
                "catalog.pdf"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Content-Type is PDF', function () {",
                  "  pm.expect(pm.response.headers.get('Content-Type')).to.include('application/pdf');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Mercure",
      "item": [
        {
          "name": "Subscribe project events (SSE)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "text/event-stream"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/.well-known/mercure?topic=project/{{projectCode}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                ".well-known",
                "mercure"
              ],
              "query": [
                {
                  "key": "topic",
                  "value": "project/{{projectCode}}"
                }
              ]
            },
            "description": "Postman peut ouvrir la requete SSE, mais le flux reste volontairement ouvert tant que le hub Mercure est actif."
          }
        }
      ]
    }
  ]

  "item": [
    {
      "name": "Projects",
      "item": [
        {
          "name": "Create project",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Tournage A\",\n  \"deviceId\": \"ios-device-1\",\n  \"displayName\": \"Simon\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/projects",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "projects"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', function () { pm.response.to.have.status(201); });",
                  "const json = pm.response.json();",
                  "if (json.code) pm.collectionVariables.set('projectCode', json.code);"
                ]
              }
            }
          ]
        },
        {
          "name": "Join project",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"{{projectCode}}\",\n  \"deviceId\": \"ios-device-2\",\n  \"displayName\": \"Marie\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/projects/join",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "projects",
                "join"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Get project",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/projects/{{projectCode}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [

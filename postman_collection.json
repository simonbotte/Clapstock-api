            "body": {
              "mode": "raw",
              "raw": "{\n  \"deviceId\": \"ios-device-1\",\n  \"title\": \"Lampe\",\n  \"description\": \"Lampe de bureau achetee pour le tournage.\",\n  \"buyPrice\": \"12.50\",\n  \"soldPrice\": \"20.00\",\n  \"quantity\": 1\n}"

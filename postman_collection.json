    {
      "name": "Photos",
      "item": [
        {
          "name": "Upload photo",
          "request": {
            "method": "POST",
            "header": [],
            "description": "Avant d'envoyer cette requete, selectionne un fichier image local dans Body > form-data > photo. Postman n'importe pas de chemin fichier depuis une collection JSON.",
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "photo",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/projects/{{projectCode}}/items/{{itemId}}/photos",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "projects",
                "{{projectCode}}",
                "items",
                "{{itemId}}",
                "photos"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', function () { pm.response.to.have.status(201); });",
                  "const json = pm.response.json();",
                  "if (json.id) pm.collectionVariables.set('photoId', String(json.id));"
                ]
              }
            }
          ]
        },
        {
          "name": "Delete photo",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/projects/{{projectCode}}/items/{{itemId}}/photos/{{photoId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
